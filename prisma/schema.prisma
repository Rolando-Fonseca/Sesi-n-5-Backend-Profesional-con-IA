// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEOUT
  DELIVERY
}

// ============================================================================
// MODELS
// ============================================================================

/// Gestiona clientes y personal del sistema
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      UserRole @default(CUSTOMER)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  orders            Order[]
  reviews           Review[]
  reservations      Reservation[]
  staffAssignments  StaffAssignment[]
  restaurants       Restaurant[] // Restaurantes que posee (owner)

  @@index([email])
  @@index([role])
}

/// Información de los restaurantes
model Restaurant {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  cuisineType String?
  ownerId     String
  phone       String
  email       String
  websiteUrl  String?
  logoUrl     String?
  rating      Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  owner              User               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  locations          Location[]
  categories         Category[]
  dishes             Dish[]
  tables             Table[]
  orders             Order[]
  reviews            Review[]
  staffAssignments   StaffAssignment[]

  @@index([ownerId])
  @@index([isActive])
}

/// Múltiples ubicaciones por restaurante
model Location {
  id         String   @id @default(cuid())
  address    String
  city       String
  state      String?
  postalCode String?
  country    String   @default("Mexico")
  latitude   Float?
  longitude  Float?
  openingTime String?  // HH:MM formato
  closingTime String?  // HH:MM formato
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relaciones
  tables   Table[]
  orders   Order[]

  @@index([restaurantId])
  @@index([latitude, longitude])
}

/// Categorías de platos en el menú
model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconUrl     String?
  displayOrder Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relaciones
  dishes Dish[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

/// Platos del menú de los restaurantes
model Dish {
  id               String   @id @default(cuid())
  name             String
  description      String?
  price            Float
  imageUrl         String?
  preparationTime  Int?     // En minutos
  isAvailable      Boolean  @default(true)
  ingredients      String?
  allergens        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relaciones
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([restaurantId])
  @@index([isAvailable])
}

/// Mesas disponibles en una ubicación
model Table {
  id        String      @id @default(cuid())
  number    String
  capacity  Int
  status    TableStatus @default(AVAILABLE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relaciones
  reservations Reservation[]
  orders       Order[]

  @@unique([locationId, number])
  @@index([locationId])
  @@index([restaurantId])
  @@index([status])
}

/// Órdenes de comida
model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  status        OrderStatus @default(PENDING)
  type          OrderType   @default(DINE_IN)
  totalAmount   Float
  discountAmount Float      @default(0)
  taxAmount      Float      @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  // Relaciones
  items   OrderItem[]
  reviews Review[]

  @@index([userId])
  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
}

/// Items individuales en una orden
model OrderItem {
  id              String   @id @default(cuid())
  quantity        Int
  unitPrice       Float
  subtotal        Float
  specialInstructions String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  dishId String
  dish   Dish   @relation(fields: [dishId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([dishId])
}

/// Sistema de reseñas y calificaciones
model Review {
  id                 String   @id @default(cuid())
  rating             Int      // 1-5
  title              String?
  comment            String?
  isVerifiedPurchase Boolean  @default(false)
  helpfulCount       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}

/// Sistema de reservas
model Reservation {
  id              String            @id @default(cuid())
  reservationDate DateTime
  reservationTime String            // HH:MM formato
  guestCount      Int
  specialRequests String?
  status          ReservationStatus @default(CONFIRMED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tableId String
  table   Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tableId])
  @@index([reservationDate])
  @@index([status])
}

/// Asignación de personal a restaurantes
model StaffAssignment {
  id       String   @id @default(cuid())
  position String
  hirDate  DateTime
  endDate  DateTime?
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId, hirDate])
  @@index([restaurantId])
  @@index([userId])
  @@index([isActive])
}

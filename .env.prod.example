# Restaurants Backend - Production Environment Configuration
# 
# IMPORTANT: This is an EXAMPLE ONLY. 
# Copy this file to .env.prod and fill with ACTUAL PRODUCTION VALUES
# NEVER commit .env.prod to Git - it contains sensitive information

# ============================================================================
# ⚠️ CRITICAL - MUST CHANGE THESE FOR PRODUCTION
# ============================================================================

# Environment Type
NODE_ENV=production

# Server Port (Easypanel will map external port to this)
PORT=3000

# CORS Configuration - MUST match your production domain
# Examples: https://api.restaurants.com, https://restaurants-production.easypanel.io
CORS_ORIGIN=https://your-production-domain.com

# Database Connection String
# Format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]
# Get this from Easypanel after creating the database
# Example: postgresql://restaurants_user:secure_password@db.easypanel.local:5432/restaurants_prod
DATABASE_URL=postgresql://restaurants_user:RestaurantsSecure123!%40%23@localhost:5432/restaurants_prod

# JWT Configuration - GENERATE NEW SECURE VALUES FOR PRODUCTION
# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_VALUE_FROM_OPENSSL
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_SECURE_RANDOM_VALUE
JWT_REFRESH_EXPIRATION=7d

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

APP_NAME=Restaurants API
APP_VERSION=1.0.0
APP_DESCRIPTION=Complete restaurant management REST API

# Logging Level (debug|info|warn|error)
# Set to 'info' for production to reduce noise
LOG_LEVEL=info

# ============================================================================
# EMAIL CONFIGURATION (Optional but recommended)
# ============================================================================
# Configure if you want to send emails (notifications, password resets, etc.)

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-production-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# Email sender address visible to users
MAIL_FROM=noreply@your-restaurants-domain.com

# ============================================================================
# REDIS CONFIGURATION (Optional - for future caching)
# ============================================================================
# If you need caching (sessions, rate limiting), configure Redis

REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# AWS S3 CONFIGURATION (Optional - for future file uploads)
# ============================================================================
# If you want to store images/files in S3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ============================================================================
# ANALYTICS & MONITORING (Optional)
# ============================================================================

SENTRY_DSN=
DATADOG_API_KEY=

# ============================================================================
# FEATURE FLAGS (Optional - for A/B testing)
# ============================================================================

FEATURE_NEW_BOOKING_FLOW=false
FEATURE_ADVANCED_SEARCH=false

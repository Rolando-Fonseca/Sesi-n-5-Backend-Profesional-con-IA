FROM node:18-slim

# Instalamos lo necesario para Prisma
RUN apt-get update -y && apt-get install -y openssl

WORKDIR /app

# Copiamos solo los archivos de configuración primero
COPY package*.json ./
COPY prisma ./prisma/

# Instalamos TODAS las dependencias (incluyendo el Nest CLI)
RUN npm install

# Copiamos el resto del código
COPY . .

# Ejecutamos el build usando el comando de tu package.json
RUN npm run build

# Exponemos el puerto
EXPOSE 3000

# Usamos tu comando de producción
CMD ["npm", "run", "start:prod"]